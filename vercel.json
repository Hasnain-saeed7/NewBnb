{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "views/**",
          "public/**",
          "utils/**",
          "controllers/**",
          "models/**",
          "routes/**",
          "cloudinary/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/output\\.css",
      "dest": "/public/output.css"
    },
    {
      "src": "/home\\.css",
      "dest": "/public/home.css"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}
