<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="flex-1 flex items-center justify-center py-12 px-4">
      <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">

          <!-- Icon + Title -->
          <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background-color:#fff0f3">
              <i class="fas fa-key text-2xl" style="color:#FF385C"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Forgot your password?</h1>
            <p class="text-gray-500 text-sm mt-2 text-center leading-relaxed">
              No worries! Enter your email and we'll send you a<br/>verification code to reset your password.
            </p>
          </div>

          <%- include('../partials/errors') %>

          <!-- Success flash -->
          <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm flex items-center gap-2 mb-4">
              <i class="fas fa-check-circle"></i>
              <span><%= success %></span>
            </div>
          <% } %>

          <form action="/forgot-password" method="POST" class="space-y-5">

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email address</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400 pointer-events-none">
                  <i class="fas fa-envelope text-sm"></i>
                </span>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>"
                  class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none transition"
                  onfocus="this.style.borderColor='#FF385C';this.style.boxShadow='0 0 0 3px rgba(255,56,92,0.15)'"
                  onblur="this.style.borderColor='';this.style.boxShadow=''"
                  required
                  autocomplete="email" />
              </div>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full text-white py-3 rounded-xl font-semibold text-sm transition duration-200 flex items-center justify-center gap-2 mt-2"
              style="background-color:#FF385C"
              onmouseover="this.style.backgroundColor='#e0314f'"
              onmouseout="this.style.backgroundColor='#FF385C'">
              <i class="fas fa-paper-plane"></i>
              Send OTP
            </button>
          </form>

          <p class="text-center text-sm text-gray-500 mt-6">
            Remembered your password?
            <a href="/login" class="font-semibold hover:underline" style="color:#FF385C">Sign in</a>
          </p>

        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
