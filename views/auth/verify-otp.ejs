<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="flex-1 flex items-center justify-center py-12 px-4">
      <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">

          <!-- Icon + Title -->
          <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background-color:#fff0f3">
              <i class="fas fa-envelope-open-text text-2xl" style="color:#FF385C"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Check your inbox</h1>
            <p class="text-gray-500 text-sm mt-2 text-center leading-relaxed">
              We sent a 6-digit code to<br/>
              <strong class="text-gray-800"><%= email %></strong>
            </p>
          </div>

          <!-- Errors -->
          <%- include('../partials/errors') %>

          <!-- Success flash (e.g. resend) -->
          <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl text-sm flex items-center gap-2 mb-4">
              <i class="fas fa-check-circle"></i>
              <span><%= success %></span>
            </div>
          <% } %>

          <form action="/verify-otp" method="POST" class="space-y-6">
            <!-- 6 individual digit boxes -->
            <div class="flex justify-center gap-2.5" id="otp-boxes">
              <% for (let i = 0; i < 6; i++) { %>
                <input
                  type="text"
                  maxlength="1"
                  inputmode="numeric"
                  pattern="[0-9]"
                  data-index="<%= i %>"
                  class="otp-digit w-12 h-14 text-center text-2xl font-bold border-2 border-gray-200
                         rounded-xl focus:outline-none transition"
                  onfocus="this.style.borderColor='#FF385C';this.style.boxShadow='0 0 0 3px rgba(255,56,92,0.15)'"
                  onblur="this.style.borderColor='';this.style.boxShadow=''"
                  required
                />
              <% } %>
            </div>

            <!-- Hidden field that collects the full 6-digit code -->
            <input type="hidden" name="otp" id="otp-hidden" />

            <button
              type="submit"
              class="w-full text-white py-3 rounded-xl font-semibold text-sm transition duration-200 flex items-center justify-center gap-2"
              style="background-color:#FF385C"
              onmouseover="this.style.backgroundColor='#e0314f'" onmouseout="this.style.backgroundColor='#FF385C'">
              <i class="fas fa-shield-alt"></i>
              Verify &amp; Proceed
            </button>
          </form>

          <!-- Resend -->
          <p class="text-center text-sm text-gray-500 mt-6">
            Didn't receive a code?
            <form action="/resend-otp" method="POST" class="inline">
              <button type="submit" class="font-semibold hover:underline" style="color:#FF385C">
                Resend code
              </button>
            </form>
          </p>

          <!-- Go back -->
          <p class="text-center text-sm text-gray-400 mt-2">
            <a href="/signup" class="hover:underline">
              <i class="fas fa-arrow-left mr-1"></i> Back to sign up
            </a>
          </p>

        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- JS: auto-focus next box, handle backspace, assemble hidden OTP -->
    <script>
      const digits = document.querySelectorAll('.otp-digit');
      const hidden = document.getElementById('otp-hidden');

      digits.forEach((input, idx) => {
        // Only allow digits
        input.addEventListener('keypress', (e) => {
          if (!/[0-9]/.test(e.key)) e.preventDefault();
        });

        input.addEventListener('input', () => {
          input.value = input.value.replace(/\D/, '');
          if (input.value && idx < digits.length - 1) {
            digits[idx + 1].focus();
          }
          assembleOtp();
        });

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && !input.value && idx > 0) {
            digits[idx - 1].focus();
          }
        });

        // Handle paste on the first box
        input.addEventListener('paste', (e) => {
          const pasted = (e.clipboardData || window.clipboardData)
                          .getData('text').replace(/\D/g, '').slice(0, 6);
          if (pasted.length === 6) {
            e.preventDefault();
            digits.forEach((d, i) => { d.value = pasted[i] || ''; });
            digits[5].focus();
            assembleOtp();
          }
        });
      });

      function assembleOtp() {
        hidden.value = Array.from(digits).map(d => d.value).join('');
      }

      // Pre-fill boxes form the hidden field on validation error
      const prefilledOtp = hidden.value;
      if (prefilledOtp) {
        prefilledOtp.split('').forEach((ch, i) => { if (digits[i]) digits[i].value = ch; });
      }
    </script>
  </body>
</html>
