<%- include('../partials/head') %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  </head>
  <body class="bg-gray-100 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="container mx-auto mt-12 p-8 bg-white rounded-lg shadow-md max-w-md">

      <!-- Icon + Title -->
      <div class="flex flex-col items-center mb-6">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-4">
          <i class="fas fa-envelope-open-text text-red-500 text-2xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-800">Check your inbox</h1>
        <p class="text-gray-500 text-sm mt-2 text-center">
          We sent a 6-digit code to
          <strong class="text-gray-700"><%= email %></strong>.<br/>
          Enter it below to verify your account.
        </p>
      </div>

      <!-- Errors -->
      <%- include('../partials/errors') %>

      <!-- Success flash (e.g. resend) -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
          <i class="fas fa-check-circle mr-2"></i>
          <span><%= success %></span>
        </div>
      <% } %>

      <form action="/verify-otp" method="POST" class="space-y-5">
        <!-- 6 individual digit boxes -->
        <div class="flex justify-center gap-3" id="otp-boxes">
          <% for (let i = 0; i < 6; i++) { %>
            <input
              type="text"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              data-index="<%= i %>"
              class="otp-digit w-12 h-14 text-center text-2xl font-bold border-2 border-gray-300
                     rounded-lg focus:outline-none focus:border-red-500 focus:ring-2
                     focus:ring-red-200 transition"
              required
            />
          <% } %>
        </div>

        <!-- Hidden field that collects the full 6-digit code -->
        <input type="hidden" name="otp" id="otp-hidden" />

        <button
          type="submit"
          class="w-full bg-red-500 text-white py-3 rounded-md hover:bg-red-600
                 focus:ring-4 focus:ring-red-300 font-medium transition duration-300
                 flex items-center justify-center gap-2">
          <i class="fas fa-shield-alt"></i>
          Verify Email
        </button>
      </form>

      <!-- Resend -->
      <p class="text-center text-sm text-gray-500 mt-5">
        Didn't receive a code?
        <form action="/resend-otp" method="POST" class="inline">
          <button type="submit" class="text-red-500 hover:underline font-medium">
            Resend code
          </button>
        </form>
      </p>

      <!-- Go back -->
      <p class="text-center text-sm text-gray-400 mt-2">
        <a href="/signup" class="hover:underline">
          <i class="fas fa-arrow-left mr-1"></i> Back to sign up
        </a>
      </p>
    </main>

    <%- include('../partials/footer') %>

    <!-- JS: auto-focus next box, handle backspace, assemble hidden OTP -->
    <script>
      const digits = document.querySelectorAll('.otp-digit');
      const hidden = document.getElementById('otp-hidden');

      digits.forEach((input, idx) => {
        // Only allow digits
        input.addEventListener('keypress', (e) => {
          if (!/[0-9]/.test(e.key)) e.preventDefault();
        });

        input.addEventListener('input', () => {
          input.value = input.value.replace(/\D/, '');
          if (input.value && idx < digits.length - 1) {
            digits[idx + 1].focus();
          }
          assembleOtp();
        });

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Backspace' && !input.value && idx > 0) {
            digits[idx - 1].focus();
          }
        });

        // Handle paste on the first box
        input.addEventListener('paste', (e) => {
          const pasted = (e.clipboardData || window.clipboardData)
                          .getData('text').replace(/\D/g, '').slice(0, 6);
          if (pasted.length === 6) {
            e.preventDefault();
            digits.forEach((d, i) => { d.value = pasted[i] || ''; });
            digits[5].focus();
            assembleOtp();
          }
        });
      });

      function assembleOtp() {
        hidden.value = Array.from(digits).map(d => d.value).join('');
      }

      // Pre-fill boxes form the hidden field on validation error
      const prefilledOtp = hidden.value;
      if (prefilledOtp) {
        prefilledOtp.split('').forEach((ch, i) => { if (digits[i]) digits[i].value = ch; });
      }
    </script>
  </body>
</html>
