<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="max-w-2xl mx-auto px-4 sm:px-6 py-12">

      <h1 class="text-3xl font-bold tracking-tight text-gray-900 mb-2">
        <%= editing ? 'Edit Your Home' : 'List Your Home' %>
      </h1>
      <p class="text-sm text-gray-500 mb-8">Fill in the details below and upload photos of your space.</p>

      <form
        action="/host/<%= editing ? 'edit-home' : 'add-home' %>"
        method="POST"
        enctype="multipart/form-data"
        class="space-y-6"
        id="homeForm"
      >
        <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />

        <!-- ── Basic Info ─────────────────────────────────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 space-y-4">
          <h2 class="text-base font-semibold text-gray-800 mb-1">Property Info</h2>

          <div>
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">House Name</label>
            <input type="text" name="houseName"
              value="<%= editing ? home.houseName : '' %>"
              placeholder="e.g. Cosy Beach Cabin"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-rose-400" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Price / Night ($)</label>
              <input type="number" name="price"
                value="<%= editing ? home.price : '' %>"
                placeholder="0"
                min="1"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-rose-400" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Rating (1–5)</label>
              <input type="number" name="rating"
                value="<%= editing ? home.rating : '' %>"
                placeholder="e.g. 4.8"
                min="1" max="5" step="0.1"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-rose-400" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Location</label>
            <div class="relative">
              <input type="text" name="location" id="locationInput"
                value="<%= editing ? home.location : '' %>"
                placeholder="Search city, country… e.g. Karachi, Pakistan"
                autocomplete="off"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-rose-400" />
              <ul id="locationSuggestions"
                class="hidden absolute z-50 left-0 right-0 bg-white border border-gray-200 rounded-xl mt-1 shadow-xl overflow-hidden max-h-64 overflow-y-auto">
              </ul>
            </div>
            <p id="locationError" class="hidden mt-1 text-xs text-rose-600 font-medium">⚠ Please select a real location from the suggestions.</p>
            <input type="hidden" name="lng" id="lngInput" value="<%= editing && home && home.geometry && home.geometry.coordinates ? home.geometry.coordinates[0] : '' %>" />
            <input type="hidden" name="lat" id="latInput" value="<%= editing && home && home.geometry && home.geometry.coordinates ? home.geometry.coordinates[1] : '' %>" />
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1">Description</label>
            <textarea name="description" rows="4"
              placeholder="Describe your space, the neighbourhood, nearby attractions…"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-rose-400 resize-none"><%= editing ? home.description : '' %></textarea>
          </div>
        </div>

        <!-- ── Photo Uploads ──────────────────────────────────────────── -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
          <h2 class="text-base font-semibold text-gray-800 mb-1">Photos</h2>
          <p class="text-xs text-gray-500 mb-5">Upload one main photo and up to four additional views. Each must be a unique file.</p>

          <!-- Main Image -->
          <div
            class="relative flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-2xl p-8 mb-4 cursor-pointer hover:border-rose-400 hover:bg-rose-50 transition"
            onclick="document.getElementById('mainImageInput').click()"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 text-gray-400 mb-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 19.5h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            <p class="text-sm font-semibold text-gray-700">Main Hero Photo</p>
            <p class="text-xs text-gray-400 mt-1" id="mainImageLabel">
              <% if (editing && home.photo && home.photo.filename) { %>Current: <%= home.photo.filename.split('/').pop() %><% } else { %>Click to upload<% } %>
            </p>
            <input
              id="mainImageInput"
              type="file"
              name="photo"
              accept="image/jpg,image/jpeg,image/png"
              class="hidden"
              onchange="previewLabel(this, 'mainImageLabel'); validateUnique()"
            />
          </div>

          <!-- Sub-images 2x2 grid -->
          <div class="grid grid-cols-2 gap-3" id="subImagesGrid">

            <% const subLabels = ['image1','image2','image3','image4']; %>
            <% const subCaptions = ['View 2','View 3','View 4','View 5']; %>

            <% for (let i = 0; i < 4; i++) { %>
              <div
                class="relative flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl p-5 cursor-pointer hover:border-rose-400 hover:bg-rose-50 transition"
                onclick="document.getElementById('sub<%= i+1 %>Input').click()"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-gray-400 mb-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <p class="text-xs font-semibold text-gray-600"><%= subCaptions[i] %></p>
                <p class="text-xs text-gray-400 mt-0.5" id="sub<%= i+1 %>Label">
                  <% if (editing && home[subLabels[i]] && home[subLabels[i]].filename) { %>Current: <%= home[subLabels[i]].filename.split('/').pop() %><% } else { %>Optional<% } %>
                </p>
                <input
                  id="sub<%= i+1 %>Input"
                  type="file"
                  name="<%= subLabels[i] %>"
                  accept="image/jpg,image/jpeg,image/png"
                  class="hidden"
                  onchange="previewLabel(this, 'sub<%= i+1 %>Label'); validateUnique()"
                />
              </div>
            <% } %>

          </div>

          <!-- Duplicate warning -->
          <p id="dupWarning" class="hidden mt-3 text-xs text-rose-600 font-medium">⚠ Two or more uploads share the same filename. Please choose unique images.</p>
        </div>

        <!-- ── Submit ─────────────────────────────────────────────────── -->
        <button type="submit"
          class="w-full bg-rose-500 hover:bg-rose-600 active:scale-95 text-white font-semibold py-3.5 rounded-2xl text-sm tracking-wide transition duration-200 shadow-sm">
          <%= editing ? 'Update Home' : 'List Home' %>
        </button>

      </form>
    </main>

    <script>
      function previewLabel(input, labelId) {
        const label = document.getElementById(labelId);
        if (input.files && input.files[0]) {
          label.textContent = input.files[0].name;
        }
      }

      function validateUnique() {
        const inputs = ['mainImageInput','sub1Input','sub2Input','sub3Input','sub4Input'];
        const names = inputs
          .map(id => document.getElementById(id)?.files?.[0]?.name)
          .filter(Boolean);
        const hasDup = names.length !== new Set(names).size;
        document.getElementById('dupWarning').classList.toggle('hidden', !hasDup);
      }

      // ── Location Autocomplete (Mapbox Geocoding v5, global) ────────────
      const MAPBOX_TOKEN = '<%= process.env.MAPBOX_TOKEN %>';
      let locationValid = <%= (editing && home && home.geometry && home.geometry.coordinates && home.geometry.coordinates[0] !== 0) ? 'true' : 'false' %>;

      const locationInput   = document.getElementById('locationInput');
      const suggestionsList = document.getElementById('locationSuggestions');
      const locationError   = document.getElementById('locationError');
      let debounceTimer;

      locationInput.addEventListener('input', function () {
        locationValid = false;
        document.getElementById('lngInput').value = '';
        document.getElementById('latInput').value = '';
        locationError.classList.add('hidden');
        clearTimeout(debounceTimer);
        const q = this.value.trim();
        if (q.length < 2) { hideSuggestions(); return; }
        debounceTimer = setTimeout(() => fetchSuggestions(q), 300);
      });

      // Use blur with delay so mousedown on a suggestion fires first
      locationInput.addEventListener('blur', () => setTimeout(hideSuggestions, 200));

      async function fetchSuggestions(query) {
        try {
          // No proximity param = truly global results (no IP-based country bias)
          const url = 'https://api.mapbox.com/geocoding/v5/mapbox.places/'
            + encodeURIComponent(query)
            + '.json?access_token=' + MAPBOX_TOKEN
            + '&autocomplete=true&limit=6&language=en'
            + '&types=country,region,district,place,locality';
          const res = await fetch(url);
          if (!res.ok) return;
          const data = await res.json();
          renderSuggestions(data.features || []);
        } catch (e) { /* network error — silently ignore */ }
      }

      function renderSuggestions(features) {
        suggestionsList.innerHTML = '';
        if (!features.length) { hideSuggestions(); return; }
        features.forEach(function (f) {
          const li = document.createElement('li');
          li.className = 'flex items-center gap-3 px-4 py-3 hover:bg-rose-50 cursor-pointer text-sm text-gray-800 border-b border-gray-100 last:border-0';
          // Pin icon
          li.innerHTML =
            '<svg class="w-4 h-4 text-rose-400 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">'
            + '<path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/>'
            + '</svg>'
            + '<span class="truncate">' + escHtml(f.place_name) + '</span>';
          // mousedown fires BEFORE blur, so selection is captured before dropdown closes
          li.addEventListener('mousedown', function (e) {
            e.preventDefault();
            pickLocation(f);
          });
          suggestionsList.appendChild(li);
        });
        suggestionsList.classList.remove('hidden');
      }

      function hideSuggestions() {
        suggestionsList.classList.add('hidden');
        suggestionsList.innerHTML = '';
      }

      function pickLocation(feature) {
        const [lng, lat] = feature.geometry.coordinates;
        locationInput.value = feature.place_name;
        document.getElementById('lngInput').value = lng;
        document.getElementById('latInput').value = lat;
        locationValid = true;
        locationError.classList.add('hidden');
        hideSuggestions();
      }

      function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      document.getElementById('homeForm').addEventListener('submit', function (e) {
        if (!locationValid) {
          e.preventDefault();
          locationError.classList.remove('hidden');
          locationInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
          locationInput.focus();
        }
      });
    </script>

    <%- include('../partials/footer') %>
  </body>
</html>