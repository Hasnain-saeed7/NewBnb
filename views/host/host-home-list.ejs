<%- include('../partials/head') %>
  </head>
  <body class="min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <!-- Welcoming header -->
      <div class="mb-8">
        <div class="text-center mb-5">
          <h2 class="text-3xl font-bold text-gray-900 tracking-tight">
            Welcome back, <span class="text-rose-500"><%= locals.user ? locals.user.firstName : 'Host' %>!</span>
          </h2>
          <p class="text-sm text-gray-400 mt-1">
            <% if (search) { %>
              <%= registeredHomes.length %> result<%= registeredHomes.length !== 1 ? 's' : '' %> for "<%= search %>"
            <% } else { %>
              <%= registeredHomes.length %> home<%= registeredHomes.length !== 1 ? 's' : '' %> listed by you.
            <% } %>
          </p>
        </div>
        <!-- Search bar -->
        <form action="/host/host-home-list" method="GET" class="flex items-center max-w-md mx-auto border border-gray-300 rounded-full bg-white shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
          <input
            type="text"
            name="search"
            value="<%= search %>"
            placeholder="Search your homes…"
            class="flex-1 pl-5 pr-2 py-2.5 text-sm text-gray-700 placeholder-gray-400 bg-transparent focus:outline-none"
          />
          <% if (search) { %>
            <a href="/host/host-home-list" class="flex items-center justify-center w-8 h-8 mr-1 text-gray-400 hover:text-gray-600 transition" title="Clear search">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
              </svg>
            </a>
          <% } %>
          <button type="submit" class="flex items-center justify-center m-1 w-9 h-9 bg-rose-500 hover:bg-rose-600 text-white rounded-full shrink-0 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </button>
        </form>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300">
            <div class="relative aspect-video overflow-hidden rounded-xl">
              <img src="<%= home.photo && home.photo.url %>" alt="<%= home.houseName %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
            </div>
            <div class="pt-3 pb-1">
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-sm font-semibold text-gray-900 leading-tight line-clamp-1"><%= home.houseName %></h3>
                <div class="flex items-center gap-0.5 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-gray-900">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-gray-700 font-medium"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-xs text-gray-500 mt-0.5"><%= home.location %></p>
              <p class="text-sm text-gray-900 mt-1">
                <span class="font-semibold">Rs<%= home.price %></span>
                <span class="text-gray-500 font-normal"> / night</span>
              </p>
              <!-- Edit & Delete buttons -->
              <div class="mt-3 flex items-center gap-2 pb-1">
                <a href="/host/edit-home/<%=home._id%>?editing=true"
                  class="flex-1 inline-flex items-center justify-center gap-1 border border-gray-300 hover:border-rose-400 hover:text-rose-500 text-gray-600 text-xs font-semibold py-2 px-2 rounded-lg transition duration-200">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-3.5 h-3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                  </svg>
                  Edit
                </a>
                <form action="/host/delete-home/<%= home._id %>" method="POST" class="flex-1">
                  <button type="submit"
                    class="w-full inline-flex items-center justify-center gap-1 border border-gray-300 hover:border-red-400 hover:text-red-500 text-gray-600 text-xs font-semibold py-2 px-2 rounded-lg transition duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-3.5 h-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                    Delete
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>

