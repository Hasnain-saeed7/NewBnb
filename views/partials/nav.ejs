<header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-200/70 shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ─── Desktop Layout ─────────────────────────────────────────────── -->
    <div class="hidden md:flex md:items-center h-16 gap-3">

      <!-- Left: Logo (never shrinks) -->
      <a href="/" class="flex-shrink-0 flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
          class="w-7 h-7 text-rose-500 group-hover:scale-110 transition-transform duration-200">
          <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z" />
          <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z" />
        </svg>
        <span class="text-xl font-bold text-rose-500 tracking-tight">airbnb</span>
      </a>

      <!-- Center: Search Bar (grows to fill space, capped at max-w-md) -->
      <div class="flex-grow flex justify-center px-4">
        <form action="/homes" method="GET"
          class="flex items-center w-full max-w-md border border-gray-300 rounded-full bg-white shadow-sm hover:shadow-md transition-shadow duration-200 overflow-hidden">
          <input
            type="text"
            name="search"
            placeholder="Search homes…"
            class="flex-1 pl-5 pr-2 py-2.5 text-sm text-gray-700 placeholder-gray-400 bg-transparent focus:outline-none"
          />
          <button type="submit"
            class="flex items-center justify-center m-1 w-9 h-9 bg-rose-500 hover:bg-rose-600 text-white rounded-full shrink-0 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:ring-offset-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
              stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Right: Nav Links (never shrinks) -->
      <div class="flex-shrink-0 flex items-center gap-1">
        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <a href="/homes"
              class="<%= currentPage === 'Home' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z" />
                <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z" />
              </svg>
              <span class="hidden lg:inline">Homes</span>
            </a>

            <a href="/favourites"
              class="<%= currentPage === 'favourites' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
              </svg>
              <span class="hidden lg:inline">Favourites</span>
            </a>

            <a href="/bookings"
              class="<%= currentPage === 'bookings' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M12.75 12.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM7.5 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM8.25 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM9.75 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM10.5 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM12 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM12.75 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM14.25 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM15 17.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM16.5 15.75a.75.75 0 100-1.5.75.75 0 000 1.5zM15 12.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM16.5 13.5a.75.75 0 100-1.5.75.75 0 000 1.5z" />
                <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd" />
              </svg>
              <span class="hidden lg:inline">Bookings</span>
            </a>
          <% } else { %>
            <a href="/host/host-home-list"
              class="<%= currentPage === 'host-homes' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path d="M5.223 2.25c-.497 0-.974.198-1.325.55l-1.3 1.298A3.75 3.75 0 007.5 9.75c.627.47 1.406.75 2.25.75.844 0 1.624-.28 2.25-.75.626.47 1.406.75 2.25.75.844 0 1.623-.28 2.25-.75a3.75 3.75 0 004.902-5.652l-1.3-1.299a1.875 1.875 0 00-1.325-.549H5.223z" />
                <path fill-rule="evenodd" d="M3 20.25v-8.755c1.42.674 3.08.673 4.5 0A5.234 5.234 0 009.75 12c.804 0 1.568-.182 2.25-.506a5.234 5.234 0 002.25.506c.804 0 1.567-.182 2.25-.506 1.42.674 3.08.675 4.5.001v8.755h.75a.75.75 0 010 1.5H2.25a.75.75 0 010-1.5H3zm3-6a.75.75 0 01.75-.75h3a.75.75 0 01.75.75v3a.75.75 0 01-.75.75h-3a.75.75 0 01-.75-.75v-3zm8.25-.75a.75.75 0 00-.75.75v5.25c0 .414.336.75.75.75h3a.75.75 0 00.75-.75v-5.25a.75.75 0 00-.75-.75h-3z" clip-rule="evenodd" />
              </svg>
              <span class="hidden lg:inline">Host Homes</span>
            </a>

            <a href="/host/add-home"
              class="<%= currentPage === 'addHome' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path fill-rule="evenodd" d="M12 3.75a.75.75 0 01.75.75v6.75h6.75a.75.75 0 010 1.5h-6.75v6.75a.75.75 0 01-1.5 0v-6.75H4.5a.75.75 0 010-1.5h6.75V4.5a.75.75 0 01.75-.75z" clip-rule="evenodd" />
              </svg>
              <span class="hidden lg:inline">Add Home</span>
            </a>

            <a href="/host/profile"
              class="<%= currentPage === 'hostProfile' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> inline-flex items-center gap-1.5 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
              </svg>
              <span class="hidden lg:inline">Edit Profile</span>
            </a>
          <% } %>
        <% } %>

        <div class="w-px h-5 bg-gray-200 mx-1 shrink-0"></div>

        <% if (!isLoggedIn) { %>
          <a href="/signup"
            class="<%= currentPage === 'signup' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100' %> px-3 py-2 rounded-full text-sm font-medium transition duration-200">
            Sign up
          </a>
          <a href="/login"
            class="<%= currentPage === 'login' ? 'bg-rose-600' : 'bg-rose-500 hover:bg-rose-600' %> text-white px-5 py-2 rounded-full text-sm font-semibold transition duration-200 shadow-sm">
            Log in
          </a>
        <% } else { %>
          <form action="/logout" method="POST">
            <button type="submit"
              class="inline-flex items-center gap-1.5 text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-full text-sm font-medium transition duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 006 5.25v13.5a1.5 1.5 0 001.5 1.5h6a1.5 1.5 0 001.5-1.5V15a.75.75 0 011.5 0v3.75a3 3 0 01-3 3h-6a3 3 0 01-3-3V5.25a3 3 0 013-3h6a3 3 0 013 3V9A.75.75 0 0115 9V5.25a1.5 1.5 0 00-1.5-1.5h-6zm5.03 4.72a.75.75 0 010 1.06l-1.72 1.72h10.94a.75.75 0 010 1.5H10.81l1.72 1.72a.75.75 0 11-1.06 1.06l-3-3a.75.75 0 010-1.06l3-3a.75.75 0 011.06 0z" clip-rule="evenodd" />
              </svg>
              <span class="hidden lg:inline">Logout</span>
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- ─── Mobile Layout ──────────────────────────────────────────────── -->
    <div class="md:hidden">

      <!-- Top bar: Logo + Hamburger -->
      <div class="flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
            class="w-6 h-6 text-rose-500">
            <path d="M11.47 3.84a.75.75 0 011.06 0l8.69 8.69a.75.75 0 101.06-1.06l-8.689-8.69a2.25 2.25 0 00-3.182 0l-8.69 8.69a.75.75 0 001.061 1.06l8.69-8.69z" />
            <path d="M12 5.432l8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 01-.75-.75v-4.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21a.75.75 0 01-.75.75H5.625a1.875 1.875 0 01-1.875-1.875v-6.198a2.29 2.29 0 00.091-.086L12 5.43z" />
          </svg>
          <span class="text-lg font-bold text-rose-500 tracking-tight">airbnb</span>
        </a>

        <button id="mobile-menu-button"
          class="p-2 rounded-full text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition duration-200"
          aria-label="Toggle menu">
          <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
            stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
            stroke-width="1.5" stroke="currentColor" class="w-6 h-6 hidden">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Search -->
      <div class="pb-3">
        <form action="/homes" method="GET"
          class="flex items-center border border-gray-300 rounded-full bg-white shadow-sm overflow-hidden">
          <input
            type="text"
            name="search"
            placeholder="Search homes…"
            class="flex-1 pl-5 pr-2 py-2.5 text-sm text-gray-700 placeholder-gray-400 bg-transparent focus:outline-none"
          />
          <button type="submit"
            class="flex items-center justify-center m-1 w-9 h-9 bg-rose-500 hover:bg-rose-600 text-white rounded-full shrink-0 transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5"
              stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden border-t border-gray-100 pb-3">
        <ul class="mt-2 space-y-1">
          <% if (isLoggedIn) { %>
            <% if (user && user.userType === 'guest') { %>
              <li>
                <a href="/homes"
                  class="<%= currentPage === 'Home' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Homes
                </a>
              </li>
              <li>
                <a href="/favourites"
                  class="<%= currentPage === 'favourites' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Favourites
                </a>
              </li>
              <li>
                <a href="/bookings"
                  class="<%= currentPage === 'bookings' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Bookings
                </a>
              </li>
            <% } else { %>
              <li>
                <a href="/host/host-home-list"
                  class="<%= currentPage === 'host-homes' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Host Homes
                </a>
              </li>
              <li>
                <a href="/host/add-home"
                  class="<%= currentPage === 'addHome' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Add Home
                </a>
              </li>
              <li>
                <a href="/host/profile"
                  class="<%= currentPage === 'hostProfile' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Edit Profile
                </a>
              </li>
            <% } %>
            <li class="border-t border-gray-100 mt-2 pt-2">
              <form action="/logout" method="POST">
                <button type="submit"
                  class="w-full text-left flex items-center gap-2 text-gray-700 hover:bg-gray-50 px-4 py-2.5 rounded-xl text-sm transition duration-200">
                  Logout
                </button>
              </form>
            </li>
          <% } else { %>
            <li>
              <a href="/signup"
                class="<%= currentPage === 'signup' ? 'text-rose-500 bg-rose-50 font-semibold' : 'text-gray-700 hover:bg-gray-50' %> block px-4 py-2.5 rounded-xl text-sm transition duration-200">
                Sign up
              </a>
            </li>
            <li>
              <a href="/login"
                class="block mx-4 mt-1 text-center bg-rose-500 text-white hover:bg-rose-600 py-2.5 rounded-full text-sm font-semibold transition duration-200 shadow-sm">
                Log in
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>

  </nav>
</header>

<script>
  (function () {
    const btn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const hamburger = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    btn?.addEventListener("click", function () {
      const isHidden = menu.classList.toggle("hidden");
      hamburger.classList.toggle("hidden", !isHidden);
      closeIcon.classList.toggle("hidden", isHidden);
    });
  })();
</script>
