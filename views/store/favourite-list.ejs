<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      <!-- Page heading -->
      <div class="mb-8">
        <h1 class="text-2xl font-semibold text-gray-900">Saved Homes</h1>
        <p class="text-sm text-gray-500 mt-1"><%= favouriteHomes.length %> saved place<%= favouriteHomes.length !== 1 ? 's' : '' %></p>
      </div>

      <% if (favouriteHomes.length > 0) { %>

      <!-- Card grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% favouriteHomes.forEach(home => { %>

          <!-- Card -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300">

            <!-- Image + saved heart overlay -->
            <div class="relative aspect-video overflow-hidden rounded-xl">
              <img
                src="<%= home.photo && home.photo.url %>"
                alt="<%= home.houseName %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />

              <!-- Saved heart: click to remove from favourites -->
              <form action="/favourites/delete/<%= home._id %>" method="POST" class="absolute top-2 right-2 z-10">
                <button
                  type="submit"
                  title="Remove from saved"
                  class="w-8 h-8 flex items-center justify-center rounded-full bg-white/80 backdrop-blur-sm shadow hover:scale-110 hover:bg-white transition-all duration-200 group/btn"
                >
                  <!-- Filled rose heart = currently saved -->
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                    class="w-4 h-4 text-rose-500 group-hover/btn:text-rose-600 transition-colors duration-200">
                    <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
                  </svg>
                </button>
              </form>
            </div>

            <!-- Card body -->
            <div class="pt-3 pb-1">

              <!-- Title + Rating row -->
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-sm font-semibold text-gray-900 leading-tight line-clamp-1">
                  <%= home.houseName %>
                </h3>
                <div class="flex items-center gap-0.5 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                    class="w-3.5 h-3.5 text-gray-900">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-gray-700 font-medium"><%= home.rating %></span>
                </div>
              </div>

              <!-- Location -->
              <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                  class="w-3 h-3 shrink-0 text-gray-400">
                  <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd" />
                </svg>
                <%= home.location %>
              </p>

              <!-- Price -->
              <p class="text-sm text-gray-900 mt-1">
                <span class="font-semibold">Rs<%= home.price %></span>
                <span class="text-gray-500 font-normal"> / night</span>
              </p>

              <!-- Details button -->
              <a
                href="/homes/<%= home._id %>"
                class="mt-3 inline-block border border-gray-900 text-gray-900 text-xs font-semibold rounded-lg px-4 py-2 hover:bg-gray-50 transition duration-200"
              >
                View Details
              </a>

            </div>
          </div>

        <% }) %>
      </div>

      <% } else { %>
      <!-- Empty state -->
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
          class="w-14 h-14 text-gray-300 mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
        <h2 class="text-xl font-semibold text-gray-800 mb-2">No saved homes yet</h2>
        <p class="text-sm text-gray-500 mb-6">Browse homes and tap the heart icon to save your favourites.</p>
        <a href="/homes" class="inline-block bg-rose-500 text-white text-sm font-semibold rounded-xl px-6 py-3 hover:bg-rose-600 transition duration-200">
          Explore Homes
        </a>
      </div>
      <% } %>

    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
