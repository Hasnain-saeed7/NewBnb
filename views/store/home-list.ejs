<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <%- include('../partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      <!-- Page heading -->
      <div class="mb-8">
        <h1 class="text-2xl font-semibold text-gray-900">Homes for you</h1>
        <p class="text-sm text-gray-500 mt-1"><%= registeredHomes.length %> place<%= registeredHomes.length !== 1 ? 's' : '' %> found</p>
      </div>

      <!-- Card grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% registeredHomes.forEach(home => { %>

          <!-- Card -->
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300">

            <!-- Image + heart overlay -->
            <div class="relative aspect-video overflow-hidden rounded-xl">
              <img
                src="<%= home.photo && home.photo.url %>"
                alt="<%= home.houseName %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <!-- Heart / Favourite -->
              <%- include('../partials/favourite', {home: home}) %>
            </div>

            <!-- Card body -->
            <div class="pt-3 pb-1">

              <!-- Title + Rating row -->
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-sm font-semibold text-gray-900 leading-tight line-clamp-1">
                  <%= home.houseName %>
                </h3>
                <div class="flex items-center gap-0.5 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                    class="w-3.5 h-3.5 text-gray-900">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-gray-700 font-medium"><%= home.rating %></span>
                </div>
              </div>

              <!-- Location -->
              <p class="text-xs text-gray-500 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                  class="w-3 h-3 inline-block mr-0.5 -mt-0.5 text-gray-400">
                  <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd" />
                </svg>
                <%= home.location %>
              </p>

              <!-- Price -->
              <p class="text-sm text-gray-900 mt-1">
                <span class="font-semibold">Rs<%= home.price %></span>
                <span class="text-gray-500 font-normal"> / night</span>
              </p>

              <!-- Details button -->
              <a
                href="/homes/<%= home._id %>"
                class="mt-3 inline-block border border-gray-900 text-gray-900 text-xs font-semibold rounded-lg px-4 py-2 hover:bg-gray-50 transition duration-200"
              >
                View Details
              </a>

            </div>
          </div>

        <% }) %>
      </div>

      <!-- Empty state -->
      <% if (registeredHomes.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-24 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
            stroke="currentColor" class="w-12 h-12 text-gray-300 mb-4">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          <p class="text-gray-500 text-lg font-medium">No homes found</p>
          <p class="text-gray-400 text-sm mt-1">Try a different search term</p>
        </div>
      <% } %>

    </main>

    <%- include('../partials/footer') %>
  </body>
</html>