<%- include('../partials/head') %>
  </head>
  <body class="min-h-screen flex flex-col">
    <%- include('../partials/nav') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="mb-8">
        <h1 class="text-2xl font-semibold text-gray-900">Find your next stay</h1>
        <p class="text-sm text-gray-500 mt-1"><%= registeredHomes.length %> place<%= registeredHomes.length !== 1 ? 's' : '' %> available</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% registeredHomes.forEach(home => { %>
          <div class="group bg-white rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300">
            <div class="relative aspect-video overflow-hidden rounded-xl">
              <img src="<%= home.photo && home.photo.url %>" alt="<%= home.houseName %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
            </div>
            <div class="pt-3 pb-1">
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-sm font-semibold text-gray-900 leading-tight line-clamp-1"><%= home.houseName %></h3>
                <div class="flex items-center gap-0.5 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-gray-900">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-xs text-gray-700 font-medium"><%= home.rating %></span>
                </div>
              </div>
              <p class="text-xs text-gray-500 mt-0.5"><%= home.location %></p>
              <p class="text-sm text-gray-900 mt-1">
                <span class="font-semibold">Rs<%= home.price %></span>
                <span class="text-gray-500 font-normal"> / night</span>
              </p>
              <% if (!locals.isLoggedIn) { %>
                <a href="/login" class="mt-3 flex items-center justify-center gap-1.5 w-full bg-rose-500 hover:bg-rose-600 active:scale-95 text-white text-xs font-semibold tracking-wide rounded-xl px-4 py-2.5 transition duration-200 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                    <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
                  </svg>
                  Book Now
                </a>
              <% } else if (locals.user && locals.user.userType === 'guest') { %>
                <a href="/homes/<%= home._id %>" class="mt-3 flex items-center justify-center gap-1.5 w-full bg-white hover:bg-rose-600 active:scale-95 text-black text-xs font-semibold tracking-wide rounded-xl px-4 py-2.5 transition duration-200 shadow-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 shrink-0">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                  </svg>
                  Book Now
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>

